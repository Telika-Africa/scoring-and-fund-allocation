# Polygon Amoy Testnet RPC URL (get from Alchemy or Infura)
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# Polygon Mainnet RPC URL
POLYGON_MAINNET_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Deployer wallet private key (DO NOT commit this file with real keys)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Deployed contract address (populated after deployment)
CONTRACT_ADDRESS=
